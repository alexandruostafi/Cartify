# branch-lint.config.js
#
# Defines valid branch name patterns consumed by the branch-lint step
# in .github/workflows/ci.yml.
#
# Pattern:  <verb>-<segment>[-<segment>...]
#
#   - verb     : a lowercase word (e.g. feat, fix, add, update, remove …)
#   - segment  : one or more lowercase letters, digits, or hyphens
#   - numbers  : allowed anywhere inside a segment (e.g. fix-bug-123, feat-oauth2-login)
#
# Special branches that are always allowed regardless of the pattern:
#   main, master, develop, dev, staging, release/*, hotfix/*

BRANCH_PATTERN = "^(main|master|develop|dev|staging|(release|hotfix)\/[a-z0-9][a-z0-9._-]*)$|^[a-z]+(-[a-z0-9]+)+$"
