{
  "name": "basic-shop-app",
  "version": "1.0.0",
  "description": "A basic full-stack online shop web application",
  "main": "backend/server.js",
  "scripts": {
    "start": "node backend/server.js",
    "dev": "nodemon backend/server.js",
    "seed": "node backend/seed.js",
    "test": "npm run test:unit && npm run test:integration && npm run test:selenium && npm run test:playwright",
    "test:unit": "jest --selectProjects unit",
    "test:unit:coverage": "jest --selectProjects unit --coverage",
    "test:integration": "jest --selectProjects integration --runInBand",
    "test:integration:coverage": "jest --selectProjects integration --runInBand --coverage",
    "test:selenium": "mocha 'tests/selenium/**/*.test.js' --timeout 40000",
    "test:playwright": "playwright test"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "express": "^4.18.3",
    "express-session": "^1.18.0",
    "sql.js": "^1.11.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.3.0",
    "@commitlint/config-conventional": "^19.2.2",
    "@playwright/test": "^1.44.0",
    "jest": "^29.7.0",
    "mocha": "^10.4.0",
    "nodemon": "^3.1.0",
    "selenium-webdriver": "^4.21.0",
    "supertest": "^7.0.0"
  }
}
