{
  "name": "warforge",
  "version": "1.2.1",
  "description": "A full-stack Warhammer 40K miniatures web shop with Node.js + Express backend, vanilla HTML/CSS/JS frontend, SQLite database, and automated UI tests with Selenium and Playwright.",
  "main": "backend/server.js",
  "scripts": {
    "start": "node backend/server.js",
    "dev": "nodemon backend/server.js",
    "seed": "node backend/seed.js",
    "test": "npm run test:unit && npm run test:integration && npm run test:selenium && npm run test:playwright",
    "test:unit": "jest --selectProjects unit",
    "test:unit:coverage": "jest --selectProjects unit --coverage",
    "test:integration": "jest --selectProjects integration --runInBand",
    "test:integration:coverage": "jest --selectProjects integration --runInBand --coverage",
    "test:selenium": "mocha",
    "test:selenium:ci": "mocha --reporter xunit --reporter-option output=tests/selenium/results/results.xml",
    "test:selenium:serve": "concurrently --kill-others --success first \"npm start\" \"wait-on http://localhost:3000 && mocha\"",
    "test:playwright": "playwright test"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "express": "^4.18.3",
    "express-session": "^1.18.0",
    "sql.js": "^1.11.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.3.0",
    "@commitlint/config-conventional": "^19.2.2",
    "@playwright/test": "^1.44.0",
    "concurrently": "^9.2.1",
    "jest": "^29.7.0",
    "mocha": "^10.4.0",
    "nodemon": "^3.1.0",
    "selenium-webdriver": "^4.21.0",
    "supertest": "^7.0.0",
    "wait-on": "^9.0.4"
  }
}
